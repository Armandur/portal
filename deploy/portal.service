[Unit]
Description=Portal - tjänsteportal för delad dev-VM
After=network.target

[Service]
WorkingDirectory=/home/rasmus/workspace/portal
ExecStart=/home/rasmus/workspace/portal/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8890
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
