# Alla värden är valfria - defaulterna gäller om variabeln inte sätts.

# Sökväg till SQLite-databasen
#PORTAL_DB_PATH=/home/rasmus/workspace/portal/data/portal.db

# Liggarfilen som auto-genereras
#PORTAL_LEDGER_PATH=/home/rasmus/.claude/running-services.md

# Portalens host och port
#PORTAL_HOST=0.0.0.0
#PORTAL_PORT=8890

# Hostnamn som används i länkar till tjänster
#PORTAL_SERVICE_HOST=ubuntu-ai

# Reservations-TTL i minuter
#PORTAL_RESERVATION_TTL=15

# Bas-URL för svc-CLI:t
#PORTAL_URL=http://127.0.0.1:8890
